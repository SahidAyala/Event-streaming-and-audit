# =============================================================================
# Event Streaming & Audit Platform — local dev environment
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Values here match the docker-compose.yml defaults so the project works
# out of the box after `make docker-up`.
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP / gRPC
# -----------------------------------------------------------------------------
HTTP_ADDR=:8080
GRPC_ADDR=:50051

# -----------------------------------------------------------------------------
# PostgreSQL  (docker-compose exposes 5433 on the host to avoid conflicts)
# -----------------------------------------------------------------------------
POSTGRES_DSN=postgres://events:events@localhost:5433/events?sslmode=disable

# -----------------------------------------------------------------------------
# Kafka  (9094 = EXTERNAL listener exposed by docker-compose for host access)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC=events
KAFKA_DLQ_TOPIC=events-dlq
KAFKA_GROUP_ID=consumer-service

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_ADDRS=http://localhost:9200
ELASTICSEARCH_INDEX=events

# -----------------------------------------------------------------------------
# Authentication
#
# AUTH_MODE=simple  → validate X-API-Key header (zero dependencies, good for dev)
# AUTH_MODE=jwt     → validate Authorization: Bearer <token> (multi-tenant, prod)
#
# AUTH_JWT_SECRET   → also enables POST /auth/issue and POST /tenants (JWT issuance).
#                     Required when AUTH_MODE=jwt.
# -----------------------------------------------------------------------------
AUTH_MODE=simple
AUTH_API_KEY=dev-api-key

# Uncomment to enable JWT mode and token issuance:
# AUTH_MODE=jwt
# AUTH_JWT_SECRET=change-me-use-at-least-32-random-characters

# -----------------------------------------------------------------------------
# Admin
#
# ADMIN_KEY  → protects POST /tenants (tenant provisioning + credential bootstrap).
#              Use this once per tenant to obtain the first token.
#              Keep this key secret and separate from AUTH_API_KEY.
# -----------------------------------------------------------------------------
ADMIN_KEY=admin-secret
