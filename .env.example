# =============================================================================
# Event Streaming & Audit Platform — local dev environment
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Values here match the docker-compose.yml defaults so the project works
# out of the box after `make up` or `make dev`.
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP / gRPC
# -----------------------------------------------------------------------------
HTTP_ADDR=:8080
GRPC_ADDR=:50051

# -----------------------------------------------------------------------------
# PostgreSQL  (docker-compose exposes 5433 on the host to avoid conflicts)
# -----------------------------------------------------------------------------
POSTGRES_DSN=postgres://events:events@localhost:5433/events?sslmode=disable

# -----------------------------------------------------------------------------
# Kafka  (9094 = EXTERNAL listener exposed by docker-compose for host access)
#
# Topic naming:
#   KAFKA_TOPIC defaults to "events.v1". The .v1 suffix is the escape hatch
#   for future breaking schema changes — bump to v2 without renaming.
#
# Topic routing (optional):
#   Leave KAFKA_TOPIC_ROUTES empty for single-topic mode (recommended for v1).
#   Set it to enable domain-based routing by stream_id prefix:
#     KAFKA_TOPIC_ROUTES=order:events.order.v1,user:events.user.v1
#   Events with stream_id "order:42" → events.order.v1
#   Events with unknown prefix       → KAFKA_TOPIC (fallback)
#
# Topic provisioning:
#   KAFKA_TOPIC_PARTITIONS controls partition count for newly created topics.
#   More partitions = more parallelism, but cannot be reduced after creation.
#   KAFKA_TOPIC_REPLICATION: set to 3 in production for fault tolerance.
# -----------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC=events.v1
KAFKA_DLQ_TOPIC=                    # empty = auto-derived as KAFKA_TOPIC + ".dlq"
KAFKA_GROUP_ID=consumer-service
KAFKA_TOPIC_PARTITIONS=6
KAFKA_TOPIC_REPLICATION=1

# Domain-based routing (optional, leave empty for single-topic mode):
# KAFKA_TOPIC_ROUTES=order:events.order.v1,user:events.user.v1

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_ADDRS=http://localhost:9200
ELASTICSEARCH_INDEX=events

# -----------------------------------------------------------------------------
# Authentication
#
# AUTH_MODE=simple  → validate X-API-Key header (zero dependencies, good for dev)
# AUTH_MODE=jwt     → validate Authorization: Bearer <token> (multi-tenant, prod)
#
# AUTH_JWT_SECRET   → also enables POST /auth/issue and POST /tenants (JWT issuance).
#                     Required when AUTH_MODE=jwt.
# -----------------------------------------------------------------------------
AUTH_MODE=none       # none = no credentials required (default for dev/demo)
AUTH_API_KEY=dev-api-key

# Uncomment to enable credential enforcement:
# AUTH_MODE=simple   # X-API-Key: dev-api-key
# AUTH_MODE=jwt      # Authorization: Bearer <token>
# AUTH_JWT_SECRET=change-me-use-at-least-32-random-characters

# -----------------------------------------------------------------------------
# Admin
#
# ADMIN_KEY  → protects POST /tenants (tenant provisioning + credential bootstrap).
#              Use this once per tenant to obtain the first token.
#              Keep this key secret and separate from AUTH_API_KEY.
# -----------------------------------------------------------------------------
ADMIN_KEY=admin-secret
